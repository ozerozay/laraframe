{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LaraFrame",
  "version": "0.1.1",
  "identifier": "com.laraframe.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LaraFrame",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ozerozay/laraframe/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDRUZGQzI0QTMxNUMzMzkKUldRNXd4V2pKUHp2VERoSmJGeWMrcEtHUVJ3TDMzT1NXblVvRVZrVjNENmI3ckh6NEo4eE4xRnkK"
    }
  }
}
